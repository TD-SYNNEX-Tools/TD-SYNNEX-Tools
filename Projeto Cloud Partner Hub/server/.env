# Azure SQL Server
DB_HOST=cloudpartnerhubserver.database.windows.net
DB_NAME=cloudpartnerhub-db
DB_PORT=1433

# IMPORTANTE: Seu banco está configurado para Azure AD Only
USE_AZURE_AD_AUTH=true

# SQL Authentication (não usado quando Azure AD está ativo)
