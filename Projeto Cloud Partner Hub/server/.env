DB_PASSWORD=teste@teste123

# Ambiente
NODE_ENV=production
PORT=3001

# Azure OpenAI (Opcional)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=
