# ============================================================================
# .env.example — Portal de Governança T2 (servidor Node)
# Copie para .env e preencha. NUNCA versione o .env real com segredos.
# ============================================================================

# --- Banco (Azure SQL / SQL Server local p/ dev) ---
DB_HOST=localhost
DB_NAME=cloudpartner_hub
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=
# Em dev local com container/SQL Express, normalmente:
DB_ENCRYPT=false
DB_TRUST_CERT=true

# --- Microsoft Entra ID (validação do token do portal) ---
AAD_TENANT_ID=common
AAD_CLIENT_ID=
# audience aceito no token da API (client id ou App ID URI)
AAD_API_AUDIENCE=
# Em DEV local sem Entra real, defina false para aceitar token interno de teste.
# Em produção, mantenha true.
AAD_VALIDATION_ENABLED=true

# --- Token interno (SSO php-app) ---
# Segredo compartilhado entre o portal e o php-app (HS256). Gere algo forte.
INTERNAL_TOKEN_SECRET=
INTERNAL_TOKEN_TTL=120

# --- Onboarding de usuários ---
# Domínios públicos que NUNCA entram no auto-vínculo por domínio.
PUBLIC_EMAIL_DOMAINS=gmail.com,hotmail.com,outlook.com,live.com,yahoo.com,icloud.com
# E-mails que entram automaticamente como provider (você). Separados por vírgula.
PROVIDER_EMAILS=

# --- Azure Blob Storage (arquivos das propostas) ---
# Em dev local você pode usar Azurite (emulador). Deixe vazio p/ desabilitar.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=proposals
BLOB_SAS_TTL_MINUTES=15
